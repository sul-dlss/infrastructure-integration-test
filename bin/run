#!/usr/bin/env ruby

require 'io/console'

results = []

Dir.new('spec/features').each do |spec_file|
  next if spec_file !~ /\.rb$/
  next if spec_file =~ /preassembly_reaccessioning/

  print "\nready? #{spec_file} [y/n/q] "
  input = STDIN.getch
  exit if input =~ /q/i
  next if input =~ /n/i

  result = system("bundle exec rspec spec/features/#{spec_file}", out: STDOUT)
  if result
    results << "✅ #{spec_file}"
  else
    results << "❌ #{spec_file}"
  end
end

puts results.join("\n")
